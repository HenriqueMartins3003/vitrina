# URL do site (sem barra no final)
NEXT_PUBLIC_URL=https://vitrina.com.br

# Stripe — chaves do painel stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Stripe — Price IDs dos planos (crie em stripe.com/products)
# Modo de pagamento: recorrente (subscription), mensal
NEXT_PUBLIC_STRIPE_PRICE_PRESENCA=price_XXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PRICE_VITRINA=price_XXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PRICE_AUTORIDADE=price_XXXXXXXXXXXXXXXXXXXX
