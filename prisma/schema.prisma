generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  businessName String?
  whatsapp     String?
  segment      String?
  city         String?

  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  planName             String?
  planStatus           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  briefing       Briefing?
  copies         Copy[]
  scheduledPosts ScheduledPost[]
  templates      UserTemplate[]
}

model Briefing {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  negocio     String?
  publico     String?
  tom         String?
  referencias String?
  datas       String?
  evitar      String?
  chatHistory Json?
  onboardingData Json?
  completed   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Copy {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  network  String
  type     String
  date     String
  caption  String @db.Text
  hashtags String @default("")
  status   String @default("pending")
  editText String? @db.Text
  monthRef String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, monthRef])
}

model ScheduledPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  network String
  time    String
  day     Int
  month   Int
  year    Int
  status  String @default("scheduled")
  copyId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, year, month])
}

model UserTemplate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  category   String
  network    String
  emoji      String @default("✦")
  color      String @default("var(--purple)")
  usageCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
